# # Database — local SQLite or Turso cloud
# TURSO_DATABASE_URL=file:./database.sqlite
# # TURSO_AUTH_TOKEN=          # only needed for Turso cloud

# # LLM — OpenAI or any OpenAI-compatible API (Groq, Together, etc.)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# # Image generation
# FAL_API_KEY=                  # optional — primary provider (fal.ai)
# REPLICATE_API_TOKEN=r8_...    # fallback provider

# # Telegram Bot
# BOT_TOKEN=...
# WEBAPP_URL=https://your-domain.com

# # Internal security secret (must match between bot and server)
# INTERNAL_SECRET=change-me-in-production

# # Dev mode — set to "dev" to bypass Telegram auth locally
# BOT_ENV=

# # Limits (optional defaults shown)
# IMAGE_EVERY_N=5
# FREE_MSG_LIMIT=20
# FREE_IMG_LIMIT=5
